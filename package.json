{
  "name": "weatherboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:api && tsc -b && vite build",
   "build:api": "esbuild api/src/inngest.ts --bundle --platform=node --format=esm --outfile=api/inngest.js && esbuild api/src/subscribe.ts --bundle --platform=node --format=esm --outfile=api/subscribe.js && esbuild api/src/unsubscribe.ts --bundle --platform=node --format=esm --outfile=api/unsubscribe.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/node": "^5.8.12",
    "inngest": "^4.5.0",
    "leaflet": "1.9",
    "lucide-react": "^1.8.0",
    "mongodb": "^7.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
